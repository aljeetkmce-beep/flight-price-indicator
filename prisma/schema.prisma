// Prisma Schema — Flight Price Indicator
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------
// Route
// Represents one origin → destination pair.
// -------------------------------------------------------
model Route {
  id          Int     @id @default(autoincrement())
  origin      String  // IATA airport code
  destination String  // IATA airport code
  originCity  String
  destCity    String
  active      Boolean @default(true)

  prices PriceRecord[]

  @@unique([origin, destination])
  @@index([origin])
  @@index([destination])
}

// -------------------------------------------------------
// PriceRecord
// One row = one price snapshot for a route on a specific date.
// -------------------------------------------------------
model PriceRecord {
  id       Int   @id @default(autoincrement())
  routeId  Int
  route    Route @relation(fields: [routeId], references: [id])

  price    Float
  currency String  @default("USD")

  airline  String?
  stops    Int     @default(0)
  duration String?
  layover  Int?

  departDate DateTime
  returnDate DateTime?
  tripType   String    @default("one_way")

  fetchedAt DateTime @default(now())

  @@index([routeId])
  @@index([fetchedAt])
  @@index([departDate])
  @@index([routeId, departDate])
}

// -------------------------------------------------------
// Watch
// One row per user-defined price watch (a route + alert rules).
// The daily scheduler reads this table to know what to check.
// -------------------------------------------------------
model Watch {
  id                  Int       @id @default(autoincrement())
  origin              String
  destination         String
  travelDate          String    // YYYY-MM-DD
  maxStops            Int?
  maxLayoverHours     Float?
  monitoringStartDate String    // YYYY-MM-DD
  checkTime           String    // "HH:MM" 24-h
  alertType           String    // "below_threshold" | "new_lowest" | "both"
  thresholdPrice      Float?    // INR
  email               String
  whatsapp            String?
  status              String    @default("active") // "active" | "paused"
  currentFare         Float?
  lowestFareSeen      Float?
  highestFareSeen     Float?
  lastCheckedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  history             PriceHistory[]

  @@index([status, checkTime])
}

// -------------------------------------------------------
// PriceHistory
// One row per daily fare snapshot for a Watch.
// -------------------------------------------------------
model PriceHistory {
  id          Int      @id @default(autoincrement())
  watchId     Int
  watch       Watch    @relation(fields: [watchId], references: [id], onDelete: Cascade)
  dateChecked String   // YYYY-MM-DD
  fare        Float    // INR
  currency    String   @default("INR")
  createdAt   DateTime @default(now())

  @@index([watchId])
  @@index([dateChecked])
}

// -------------------------------------------------------
// FetchLog
// Tracks each automated fetch run for observability.
// -------------------------------------------------------
model FetchLog {
  id        Int      @id @default(autoincrement())
  startedAt DateTime @default(now())
  finishedAt DateTime?
  status    String   @default("running")
  message   String?
  recordsFetched Int @default(0)

  @@index([startedAt])
}
