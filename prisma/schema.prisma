// Prisma Schema — Flight Price Indicator
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------
// Route
// Represents one origin → destination pair.
// Fixed set: 3 origins × 5 destinations = 15 routes.
// Seeded once via scripts/seed.ts
// -------------------------------------------------------
model Route {
  id          Int     @id @default(autoincrement())
  origin      String  // IATA airport code: TRV, COK, BLR
  destination String  // IATA airport code: BKK, DMK, HKT, KBV, CNX
  originCity  String  // Human-readable: Trivandrum, Kochi, Bangalore
  destCity    String  // Human-readable: Bangkok, Bangkok Don Mueang, Phuket, Krabi, Chiang Mai
  active      Boolean @default(true)

  prices PriceRecord[]

  @@unique([origin, destination])
  @@index([origin])
  @@index([destination])
}

// -------------------------------------------------------
// PriceRecord
// One row = one price snapshot for a route on a specific date.
// Fetched daily by the automation script (Phase 5).
// -------------------------------------------------------
model PriceRecord {
  id       Int   @id @default(autoincrement())
  routeId  Int
  route    Route @relation(fields: [routeId], references: [id])

  price    Float   // Price in the specified currency
  currency String  @default("USD")

  airline  String? // Carrier name or IATA code (e.g. "IndiGo", "6E")
  stops    Int     @default(0) // 0 = direct, 1 = one stop, 2 = two stops
  duration String? // Total travel time, e.g. "9h 30m"
  layover  Int?    // Layover in minutes; 0 for direct, null if unknown

  departDate DateTime  // The departure date this price applies to
  returnDate DateTime? // Set only for round trips
  tripType   String    @default("one_way") // "one_way" | "round_trip"

  fetchedAt DateTime @default(now()) // Timestamp when this record was saved

  @@index([routeId])
  @@index([fetchedAt])
  @@index([departDate])
  @@index([routeId, departDate])
}

// -------------------------------------------------------
// CachedFlight
// One row per flight option returned by the Skyscanner API.
// Cache is valid for 24 hours — checked before any live API call.
// -------------------------------------------------------
model CachedFlight {
  id            Int      @id @default(autoincrement())
  origin        String
  destination   String
  date          String   // YYYY-MM-DD departure date searched
  airline       String
  flightNumbers String
  price         Float    // USD
  stops         Int
  duration      String   // e.g. "9h 30m"
  durationMins  Int
  departureTime String   // "HH:mm"
  arrivalTime   String   // "HH:mm"
  layoverMins   Int
  cachedAt      DateTime @default(now())

  @@index([origin, destination, date])
  @@index([cachedAt])
}

// -------------------------------------------------------
// Watch
// One row per user-defined price watch (a route + alert rules).
// The daily scheduler reads this table to know what to check.
// -------------------------------------------------------
model Watch {
  id                  Int       @id @default(autoincrement())
  origin              String    // IATA code
  destination         String    // IATA code
  travelDate          String    // YYYY-MM-DD
  maxStops            Int?      // null = Any; 0/1/2 for specific limits
  maxLayoverHours     Float?    // null = no limit
  monitoringStartDate String    // YYYY-MM-DD
  checkTime           String    // "HH:MM" 24-h, e.g. "10:00"
  alertType           String    // "below_threshold" | "new_lowest" | "both"
  thresholdPrice      Float?    // INR; required when alertType includes below_threshold
  email               String
  whatsapp            String?
  status              String    @default("active") // "active" | "paused"
  currentFare         Float?    // INR — updated after each check
  lowestFareSeen      Float?    // INR
  highestFareSeen     Float?    // INR
  lastCheckedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  history             PriceHistory[]

  @@index([status, checkTime])
}

// -------------------------------------------------------
// PriceHistory
// One row per daily fare snapshot for a Watch.
// Never deleted individually; removed via cascade when Watch is deleted.
// -------------------------------------------------------
model PriceHistory {
  id          Int      @id @default(autoincrement())
  watchId     Int
  watch       Watch    @relation(fields: [watchId], references: [id], onDelete: Cascade)
  dateChecked String   // YYYY-MM-DD
  fare        Float    // INR
  currency    String   @default("INR")
  createdAt   DateTime @default(now())

  @@index([watchId])
  @@index([dateChecked])
}

// -------------------------------------------------------
// FetchLog
// Tracks each automated fetch run for observability.
// Useful for debugging and knowing when data was last refreshed.
// -------------------------------------------------------
model FetchLog {
  id        Int      @id @default(autoincrement())
  startedAt DateTime @default(now())
  finishedAt DateTime?
  status    String   @default("running") // "running" | "success" | "failed"
  message   String?  // Error message if status = "failed"
  recordsFetched Int @default(0)

  @@index([startedAt])
}
