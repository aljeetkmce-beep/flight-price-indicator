# -------------------------------------------------------
# Database
# -------------------------------------------------------
# SQLite database file path (local file, no server needed)
# The file will be created automatically on first run.
DATABASE_URL="file:./dev.db"

# -------------------------------------------------------
# Flight Data API
# -------------------------------------------------------
# Amadeus API — free tier available at: https://developers.amadeus.com
# Sign up, create an app, and copy your credentials below.
AMADEUS_API_KEY=""
AMADEUS_API_SECRET=""

# Amadeus environment: "test" (free, fake data) or "production" (real data)
AMADEUS_ENV="test"

# -------------------------------------------------------
# App Settings
# -------------------------------------------------------
# Port the app runs on (default: 3000)
PORT=3000

# Default currency for price display
DEFAULT_CURRENCY="USD"

# How many future days to check prices for (e.g., 30 = next 30 days)
PRICE_FETCH_DAYS_AHEAD=30
